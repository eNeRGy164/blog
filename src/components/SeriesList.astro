---
/**
 * SeriesList
 * Sidebar list of posts in the current series.
 */
import type { CollectionEntry } from "astro:content";
import { getSeriesWithPosts, urlifyToken } from "@/js/util.js";

interface Props {
  currentPost: CollectionEntry<"posts">;
  allPosts: CollectionEntry<"posts">[];
}

const { currentPost, allPosts } = Astro.props;
const series = currentPost.data.series;

// getSeriesWithPosts returns posts oldest-first per series
const seriesPosts = series
  ? (getSeriesWithPosts(allPosts).get(series) ?? [])
  : [];
---

{
  seriesPosts.length > 1 && (
    <aside id="series-posts">
      <h2>
        <a href={`/series/${urlifyToken(series!)}/`}>
          Posts in this series
        </a>
      </h2>
      <div>
        <nav aria-label="Series">
          <ol>
            {seriesPosts.map((post) => (
              <li>
                {post.data.permalink === currentPost.data.permalink ? (
                  <span aria-current="page">{post.data.title}</span>
                ) : (
                  <a href={post.data.permalink} target="_self">
                    {post.data.title}
                  </a>
                )}
              </li>
            ))}
          </ol>
        </nav>
      </div>
    </aside>
  )
}
