---
/**
 * FooterSeries
 * Footer series list derived from the posts collection.
 */
import type { CollectionEntry } from "astro:content";
import { urlifyToken, getSeriesWithPosts } from "@/js/util.js";

interface Props {
  posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;

const seriesMap = getSeriesWithPosts(posts);

// Sort series by the date of their oldest post (oldest series first)
const seriesSorted = Array.from(seriesMap.entries()).sort(
  (a, b) =>
    new Date(a[1][0].data.date).valueOf() - new Date(b[1][0].data.date).valueOf(),
);
---

<nav>
	<h2>Series</h2>
	<ul>
		{seriesSorted.map(([seriesName]) =>
			<li><a rel="nofollow" href={`/series/${urlifyToken(seriesName)}/`}>{seriesName}</a></li>
		)}
	</ul>
</nav>
