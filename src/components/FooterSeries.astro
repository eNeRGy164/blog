---
/**
 * FooterSeries
 * Footer series list derived from the posts collection.
 */
import type { CollectionEntry } from "astro:content";
import { urlifyToken, getSeriesWithPosts } from "@/js/util.js";

interface Props {
  posts: CollectionEntry<"posts">[];
}

const { posts } = Astro.props;

// getSeriesWithPosts iterates oldest-first, so Map insertion order = oldest series first
const seriesNames = Array.from(getSeriesWithPosts(posts).keys());
---

<nav>
	<h2>Series</h2>
	<ul>
		{seriesNames.map((seriesName) =>
			<li><a rel="nofollow" href={`/series/${urlifyToken(seriesName)}/`}>{seriesName}</a></li>
		)}
	</ul>
</nav>
